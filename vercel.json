{
  "version": 2,
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.6.0"
    }
  },
  "rewrites": [
    {
      "source": "/services",
      "destination": "/api/services.php"
    },
    {
      "source": "/contact",
      "destination": "/api/contact.php"
    },
    {
      "source": "/news",
      "destination": "/api/news.php"
    },
    {
      "source": "/tickets",
      "destination": "/api/tickets.php"
    },
    {
      "source": "/tickets-2",
      "destination": "/api/tickets-2.php"
    },
    {
      "source": "/",
      "destination": "/api/index.php"
    }
  ],
  "cleanUrls": true
}
