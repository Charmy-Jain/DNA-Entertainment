{
  "version": 2,
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.6.0"
    }
  },
  "routes": [
    {
      "src": "/(.*)\\.(css|js|webp|png|jpg|mp4|svg|eot|ttf|woff|woff2)",
      "dest": "/$1.$2"
    },
    {
      "src": "/services",
      "dest": "/api/services.php"
    },
    {
      "src": "/contact",
      "dest": "/api/contact.php"
    },
    {
      "src": "/news",
      "dest": "/api/news.php"
    },
    {
      "src": "/tickets",
      "dest": "/api/tickets.php"
    },
    {
      "src": "/tickets-2",
      "dest": "/api/tickets-2.php"
    },
    {
      "src": "/(.*).php",
      "dest": "/api/$1.php"
    },
    {
      "src": "/",
      "dest": "/api/index.php"
    }
  ],
  "cleanUrls": true
}
